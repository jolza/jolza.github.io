---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

const allProjects = (await getCollection("projects")).sort((a, b) => {
  const oa = a.data.order ?? 0;
  const ob = b.data.order ?? 0;
  if (oa !== ob) return ob - oa;
  return Number(b.data.year) - Number(a.data.year);
});

const inProgress = allProjects.filter((p) => p.data.status === "in-progress");
const completed = allProjects.filter((p) => p.data.status === "completed");
const archived = allProjects.filter((p) => p.data.status === "archived");

function url(entry: (typeof allProjects)[number]) {
  return "/projects/" + createSlug(entry.data.title, entry.slug) + "/";
}
---

<BaseLayout title="项目集" sideBarActiveItemID="projects">
  <section class="pt-6 pb-4">
    <div class="badge badge-primary badge-outline mb-4">Projects</div>
    <h1 class="text-4xl md:text-5xl font-black tracking-tight">项目集</h1>
    <p class="text-base-content/70 mt-3 max-w-2xl">
      过去几年参与和主导的一些项目。带有 <span class="badge badge-primary badge-xs">NEW</span> 的是当前正在推进的。
    </p>
  </section>

  {inProgress.length > 0 && (
    <section class="mt-10">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="text-2xl font-bold">进行中</h2>
        <span class="text-base-content/50 font-mono text-sm">// In Progress</span>
      </div>
      <div class="grid gap-5">
        {inProgress.map((p) => (
          <a
            href={url(p)}
            class="group block rounded-2xl border border-base-300 bg-base-100 hover:border-primary/40 hover:shadow-lg hover:-translate-y-0.5 transition-all overflow-hidden"
          >
            <div class="flex flex-col md:flex-row">
              <div class={`bg-gradient-to-br ${p.data.gradient} md:w-40 flex items-center justify-center p-6 text-6xl`}>
                {p.data.emoji}
              </div>
              <div class="flex-1 p-5">
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="text-xl font-bold group-hover:text-primary transition-colors">{p.data.title}</h3>
                  {p.data.badge && <span class="badge badge-primary badge-sm">{p.data.badge}</span>}
                  <span class="ml-auto text-xs text-base-content/50 font-mono">{p.data.year}</span>
                </div>
                <p class="text-base-content/70 leading-relaxed mb-3">{p.data.description}</p>
                {p.data.tags && (
                  <div class="flex flex-wrap gap-1.5">
                    {p.data.tags.map((t) => (<span class="badge badge-outline badge-sm">{t}</span>))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {completed.length > 0 && (
    <section class="mt-16">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="text-2xl font-bold">已完成</h2>
        <span class="text-base-content/50 font-mono text-sm">// Completed</span>
      </div>
      <div class="grid gap-5">
        {completed.map((p) => (
          <a
            href={url(p)}
            class="group block rounded-2xl border border-base-300 bg-base-100 hover:border-primary/40 hover:shadow-lg hover:-translate-y-0.5 transition-all overflow-hidden"
          >
            <div class="flex flex-col md:flex-row">
              <div class={`bg-gradient-to-br ${p.data.gradient} md:w-40 flex items-center justify-center p-6 text-6xl`}>
                {p.data.emoji}
              </div>
              <div class="flex-1 p-5">
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="text-xl font-bold group-hover:text-primary transition-colors">{p.data.title}</h3>
                  {p.data.badge && <span class="badge badge-primary badge-sm">{p.data.badge}</span>}
                  <span class="ml-auto text-xs text-base-content/50 font-mono">{p.data.year}</span>
                </div>
                <p class="text-base-content/70 leading-relaxed mb-3">{p.data.description}</p>
                {p.data.tags && (
                  <div class="flex flex-wrap gap-1.5">
                    {p.data.tags.map((t) => (<span class="badge badge-outline badge-sm">{t}</span>))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {archived.length > 0 && (
    <section class="mt-16">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="text-2xl font-bold">归档</h2>
        <span class="text-base-content/50 font-mono text-sm">// Archived</span>
      </div>
      <div class="grid gap-5">
        {archived.map((p) => (
          <a
            href={url(p)}
            class="group block rounded-2xl border border-base-300 bg-base-100 hover:border-primary/40 hover:shadow-lg hover:-translate-y-0.5 transition-all overflow-hidden"
          >
            <div class="flex flex-col md:flex-row">
              <div class={`bg-gradient-to-br ${p.data.gradient} md:w-40 flex items-center justify-center p-6 text-6xl opacity-70`}>
                {p.data.emoji}
              </div>
              <div class="flex-1 p-5 opacity-80">
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="text-xl font-bold group-hover:text-primary transition-colors">{p.data.title}</h3>
                  <span class="ml-auto text-xs text-base-content/50 font-mono">{p.data.year}</span>
                </div>
                <p class="text-base-content/70 leading-relaxed mb-3">{p.data.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
