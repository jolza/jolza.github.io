---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);

const allProjects = (await getCollection("projects")).sort((a, b) => {
  const oa = a.data.order ?? 0;
  const ob = b.data.order ?? 0;
  if (oa !== ob) return ob - oa;
  return Number(b.data.year) - Number(a.data.year);
});
const topProjects = allProjects.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <!-- Hero -->
  <section class="pt-6 pb-16">
    <div class="badge badge-primary badge-outline mb-4 gap-2">
      <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      Open to Collaboration
    </div>

    <h1 class="text-5xl md:text-6xl font-black leading-tight tracking-tight">
      你好，我是
      <span class="bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent">
        林智杰
      </span>
    </h1>

    <h2 class="text-2xl md:text-3xl font-semibold text-base-content/70 mt-3">
      大数据工程师 · Data Engineer
    </h2>

    <p class="text-lg text-base-content/80 mt-6 max-w-2xl leading-relaxed">
      构建有意思的东西，写能看懂的代码。
      <br class="hidden md:block" />
      专注于数据基础设施与实时计算，不定期记录一些思考。
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a class="btn btn-primary gap-2" href="mailto:your-email@example.com">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.103 0-2 .897-2 2v12c0 1.103.897 2 2 2h16c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm0 2v.511l-8 6.223-8-6.222V6h16zM4 18V9.044l7.386 5.745a.994.994 0 0 0 1.228 0L20 9.044 20.002 18H4z"/></svg>
        Let's connect
      </a>
      <a href="https://github.com/jolza" target="_blank" class="btn btn-outline gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.84-2.34 4.68-4.57 4.93.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
        GitHub
      </a>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Projects -->
  <section class="mt-16">
    <div class="flex items-baseline gap-3 mb-8">
      <h3 class="text-3xl font-bold">最近的项目</h3>
      <span class="text-base-content/50 font-mono text-sm">// Recent Work</span>
    </div>

    <div class="grid gap-5">
      {topProjects.map((p) => (
        <a
          href={"/projects/" + createSlug(p.data.title, p.slug) + "/"}
          class="group block rounded-2xl border border-base-300 bg-base-100 hover:border-primary/40 hover:shadow-lg hover:-translate-y-0.5 transition-all overflow-hidden"
        >
          <div class="flex flex-col md:flex-row">
            <div class={`bg-gradient-to-br ${p.data.gradient} md:w-40 flex items-center justify-center p-6 text-6xl`}>
              {p.data.emoji}
            </div>
            <div class="flex-1 p-5">
              <div class="flex items-center gap-2 mb-2">
                <h4 class="text-xl font-bold group-hover:text-primary transition-colors">{p.data.title}</h4>
                {p.data.badge && <span class="badge badge-primary badge-sm">{p.data.badge}</span>}
                <span class="ml-auto text-xs text-base-content/50 font-mono">{p.data.year}</span>
              </div>
              <p class="text-base-content/70 leading-relaxed mb-3">{p.data.description}</p>
              {p.data.tags && (
                <div class="flex flex-wrap gap-1.5">
                  {p.data.tags.map((t) => (
                    <span class="badge badge-outline badge-sm">{t}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-6 text-right">
      <a href="/projects" class="link link-primary font-medium">查看所有项目 →</a>
    </div>
  </section>

  <!-- Blog -->
  <section class="mt-20">
    <div class="flex items-baseline gap-3 mb-8">
      <h3 class="text-3xl font-bold">最新博客</h3>
      <span class="text-base-content/50 font-mono text-sm">// Latest Posts</span>
    </div>

    {
      last_posts.map((post) => (
        <>
          <HorizontalCard
            title={post.data.title}
            img={post.data.heroImage}
            desc={post.data.description}
            url={"/blog/" + createSlug(post.data.title, post.slug)}
            target="_self"
            badge={post.data.badge}
          />
          <div class="divider my-0" />
        </>
      ))
    }

    <div class="mt-6 text-right">
      <a href="/blog" class="link link-primary font-medium">查看所有博客 →</a>
    </div>
  </section>
</BaseLayout>
