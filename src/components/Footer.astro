---
const today = new Date();
---

<footer class="footer footer-center mb-5 pt-10 text-base-content/60">
  <div class="flex flex-col items-center gap-1">
    <div class="text-sm">
      &copy; {today.getFullYear()} 林智杰
    </div>
    <div class="text-xs opacity-75 flex flex-wrap justify-center gap-x-2">
      <span>Built with <a href="https://astro.build" target="_blank" class="font-medium hover:text-primary transition-colors">Astro</a></span>
      <span>·</span>
      <span>Hosted on <a href="https://pages.github.com/" target="_blank" class="font-medium hover:text-primary transition-colors">GitHub Pages</a></span>
    </div>
    <div class="text-xs opacity-75 whitespace-nowrap" data-site-counter style="display:none">
      总访问 <span data-site-value>-</span> 次
    </div>
  </div>
</footer>
<script is:inline>
  (function () {
    const NAMESPACE = "jolza-github-io";
    async function loadSite() {
      const el = document.querySelector("[data-site-counter]");
      const v = document.querySelector("[data-site-value]");
      if (!el || !v) return;

      const alreadyCounted = sessionStorage.getItem("site-counted");
      const endpoint = alreadyCounted ? "get" : "hit";

      try {
        const res = await fetch(`https://abacus.jasoncameron.dev/${endpoint}/${NAMESPACE}/__site__`, { cache: "no-store" });
        if (!res.ok) return;
        const data = await res.json();
        v.textContent = data.value.toLocaleString();
        el.style.display = "";
        sessionStorage.setItem("site-counted", "1");
      } catch (e) { /* silent */ }
    }
    if (!window.__siteCounterInit) {
      window.__siteCounterInit = true;
      document.addEventListener("astro:page-load", loadSite);
    }
  })();
</script>
